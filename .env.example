# ── Application ─────────────────────────────────────────
APP_ENV=development
APP_NAME=BharatAI
APP_VERSION=0.1.0
DEBUG=true
SECRET_KEY=change-me-to-random-32-char-string

# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://bharatai:bharatai_pass@localhost:5432/bharatai_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_CACHE_TTL_FEED=900
REDIS_CACHE_TTL_LEADERBOARD=600
REDIS_CACHE_TTL_OPPORTUNITIES=300

# ── JWT (RS256) ──────────────────────────────────────────
JWT_PRIVATE_KEY_PATH=./jwt_private.pem
JWT_PUBLIC_KEY_PATH=./jwt_public.pem
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=RS256

# ── Google OAuth2 ────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# ── AI / ML ──────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
HUGGINGFACE_MODEL_CLASSIFIER=facebook/bart-large-mnli
HUGGINGFACE_MODEL_EMBEDDINGS=sentence-transformers/all-MiniLM-L6-v2
CLASSIFICATION_CONFIDENCE_THRESHOLD=0.6
FAISS_INDEX_PATH=./data/faiss.index

# ── Celery ───────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_SCRAPE_INTERVAL_MINUTES=30

# ── Elasticsearch ────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_OPPORTUNITIES=bharatai_opportunities

# ── File Storage (MinIO in dev, S3 in prod) ─────────────
STORAGE_BACKEND=minio
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_RESUMES=bharatai-resumes
MINIO_BUCKET_UPLOADS=bharatai-uploads
AWS_S3_BUCKET=your-s3-bucket-name
AWS_REGION=ap-south-1

# ── Email (SMTP) ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=BharatAI
SMTP_FROM_EMAIL=noreply@bharatai.in
EMAIL_ENABLED=false

# ── Feature Flags (Unleash) ──────────────────────────────
UNLEASH_URL=http://localhost:4242/api
UNLEASH_CLIENT_KEY=unleash-client-key
FEATURE_AI_CLASSIFICATION=false
FEATURE_PERSONALIZED_FEED=false
FEATURE_INCOSCORE_ENGINE=false
FEATURE_COMMUNITY=false
FEATURE_APP_ASSISTANCE=false
FEATURE_BROWSER_AUTOMATION=false

# ── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_ANON=60
RATE_LIMIT_AUTH=300
RATE_LIMIT_AUTOFILL_PER_HOUR=20

# ── Proxy (for scraping) ─────────────────────────────────
PROXY_LIST=

# ── Monitoring ───────────────────────────────────────────
PROMETHEUS_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=bharatai-backend

# ── Notifications ────────────────────────────────────────
NOTIFICATION_DEADLINE_REMINDER_DAYS=7,1

# ── Frontend (Next.js - NEXT_PUBLIC_ prefix = exposed to browser) ────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_APP_NAME=BharatAI
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
